# Run `bun run setup` to configure these values interactively.
# Run `bun run setup --doctor` to check install readiness without writing any files.
DATABASE_URL=file:./db/custom.db
# Optional overrides for locating runtime config/state.
OPENCLAW_CONFIG_DIR=
OPENCLAW_STATE_DIR=
OPENCLAW_CONFIG_PATH=

# Provider credentials referenced from openclaw.json via ${ENV_VAR}.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
POE_API_KEY=

# ============================================================
# DEPRECATED: Runtime settings migrated to ~/.openclaw/openclaw.json
# The following env vars are deprecated and will print warnings.
# Move them to openclaw.json under the runtime.* keys shown below.
# ============================================================

# DEPRECATED: Use runtime.paths.workspaceDir in openclaw.json
OPENCLAW_WORKSPACE_DIR=

# DEPRECATED: Use runtime.session.compactionThreshold in openclaw.json
OPENCLAW_SESSION_COMPACTION_THRESHOLD=
# DEPRECATED: Use runtime.session.retainCount in openclaw.json
OPENCLAW_SESSION_RETAIN_COUNT=
# DEPRECATED: Use runtime.session.historyCapBytes in openclaw.json
OPENCLAW_HISTORY_CAP_BYTES=
# DEPRECATED: Use runtime.session.historyRetentionDays in openclaw.json
OPENCLAW_HISTORY_RETENTION_DAYS=

# DEPRECATED: Use runtime.memory.decay.halfLifeDays in openclaw.json
OPENCLAW_MEMORY_DECAY_HALF_LIFE_DAYS=
# DEPRECATED: Use runtime.memory.decay.floor in openclaw.json
OPENCLAW_MEMORY_DECAY_FLOOR=
# DEPRECATED: Use runtime.memory.decay.offloadTokenThreshold in openclaw.json
OPENCLAW_OFFLOAD_TOKEN_THRESHOLD=
# DEPRECATED: Use runtime.memory.decay.memoryDir in openclaw.json
OPENCLAW_MEMORY_DIR=

# DEPRECATED: Use runtime.paths.skillsDir in openclaw.json
OPENCLAW_SKILLS_DIR=

# DEPRECATED: Use runtime.network.appUrl in openclaw.json
OPENCLAW_APP_URL=http://localhost:3000
# DEPRECATED: Use runtime.network.allowedOrigins in openclaw.json (array)
OPENCLAW_ALLOWED_ORIGINS=

# DEPRECATED: Use runtime.websocket.port in openclaw.json
OPENCLAW_WS_PORT=3003
# DEPRECATED: Use runtime.websocket.url in openclaw.json
OPENCLAW_WS_URL=http://localhost:3003
# Client-side WebSocket URL (for browser) - still required for Next.js
NEXT_PUBLIC_OPENCLAW_WS_URL=http://localhost:3000

# ============================================================
# SECURITY & INFRASTRUCTURE (keep as env vars - secrets/meta-config)
# ============================================================

# Bearer token required for admin APIs and trusted service-to-service calls.
OPENCLAW_API_KEY=
# Set to "true" only for local-only testing to bypass internal bearer auth.
OPENCLAW_ALLOW_INSECURE_LOCAL=

# Example credentialRef mapping: credential "providers/openrouter/planner" -> env var below.
OPENCLAW_CREDENTIAL_PROVIDERS_OPENROUTER_PLANNER=

# ============================================================
# CHANNEL CONFIGURATION (now in ~/.openclaw/openclaw.json)
# ============================================================

# Telegram config now lives in ~/.openclaw/openclaw.json under "channels.telegram".
# {
#   "channels": {
#     "telegram": {
#       "botToken": "...",
#       "webhookSecret": "...",
#       "transport": "polling"
#     }
#   }
# }
# Environment variables (TELEGRAM_BOT_TOKEN, TELEGRAM_WEBHOOK_SECRET, TELEGRAM_TRANSPORT)
# are still supported as a fallback for backwards compatibility.

# WhatsApp config now lives in ~/.openclaw/openclaw.json under "channels.whatsapp".
# {
#   "channels": {
#     "whatsapp": {
#       "enabled": true,
#       "authDir": "data/whatsapp-auth"
#     }
#   }
# }
# DEPRECATED: Use channels.whatsapp.enabled in openclaw.json
WHATSAPP_ENABLED=
# DEPRECATED: Use channels.whatsapp.authDir in openclaw.json
WHATSAPP_AUTH_DIR=
