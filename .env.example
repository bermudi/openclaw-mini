DATABASE_URL=file:./db/custom.db
# Optional overrides for locating runtime config/state.
OPENCLAW_CONFIG_DIR=
OPENCLAW_STATE_DIR=
OPENCLAW_CONFIG_PATH=

# Provider credentials referenced from openclaw.json via ${ENV_VAR}.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
POE_API_KEY=

# Workspace bootstrap override for markdown memories/tools.
OPENCLAW_WORKSPACE_DIR=

# Runtime session/history tuning knobs (all optional).
OPENCLAW_SESSION_COMPACTION_THRESHOLD=
OPENCLAW_SESSION_RETAIN_COUNT=
OPENCLAW_HISTORY_CAP_BYTES=
OPENCLAW_HISTORY_RETENTION_DAYS=

# Bearer token required for admin APIs and trusted service-to-service calls.
OPENCLAW_API_KEY=
# Set to "true" only for local-only testing to bypass internal bearer auth.
OPENCLAW_ALLOW_INSECURE_LOCAL=
# Optional override for scheduler -> app calls when not using localhost:3000.
OPENCLAW_APP_URL=http://localhost:3000

# Example credentialRef mapping: credential "providers/openrouter/planner" -> env var below.
OPENCLAW_CREDENTIAL_PROVIDERS_OPENROUTER_PLANNER=
# WebSocket service configuration.
OPENCLAW_WS_PORT=3003
OPENCLAW_WS_URL=http://localhost:3003
# Client-side WebSocket URL (for browser)
NEXT_PUBLIC_OPENCLAW_WS_URL=http://localhost:3003

# Telegram bot token for outbound delivery and inbound webhook processing.
TELEGRAM_BOT_TOKEN=
# Optional secret validated against X-Telegram-Bot-Api-Secret-Token on webhook requests.
TELEGRAM_WEBHOOK_SECRET=
# Inbound Telegram transport: webhook (default) or polling.
TELEGRAM_TRANSPORT=

# Set to "true" to enable the WhatsApp adapter via Baileys. Auth state stored in data/whatsapp-auth/.
# On first run without auth state, a QR code will be generated at /api/channels/whatsapp/qr.
WHATSAPP_ENABLED=
