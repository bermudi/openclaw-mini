// OpenClaw Agent Runtime - Database Schema
// Event-driven AI agent runtime with persistent storage

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Agent - AI agent instance
model Agent {
  id          String   @id @default(cuid())
  name        String
  description String?
  model       String?
  contextWindowOverride Int?
  compactionThreshold Float?
  status      String   @default("idle") // idle, busy, error, disabled
  skills      String   @default("[]") // JSON array of skill names
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tasks       Task[]
  memories    Memory[]
  recallLogs  MemoryRecallLog[]
  sessions    Session[]
  triggers    Trigger[]
  channelBindings ChannelBinding[]
  
  @@map("agents")
}

// Session - Communication channel context
model Session {
  id          String   @id @default(cuid())
  agentId     String
  channel     String   // slack, whatsapp, telegram, imessage, webhook, internal
  channelKey  String   // unique identifier for the channel (e.g., chat_id, phone number)
  sessionScope String  @default("main")
  context     String   @default("{}") // JSON context data
  lastActive  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages    SessionMessage[]
  tasks       Task[]
  
  @@unique([agentId, sessionScope])
  @@map("sessions")
}

model SessionMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String
  content    String
  sender     String?
  channel    String?
  channelKey String?
  createdAt  DateTime @default(now())

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("session_messages")
}

// ChannelBinding - Bind a channel to an agent
model ChannelBinding {
  id         String @id @default(cuid())
  channel    String
  channelKey String
  agentId    String
  createdAt  DateTime @default(now())

  agent      Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([channel, channelKey])
  @@index([agentId])
  @@map("channel_bindings")
}

// Task - Queued task for agent execution
model Task {
  id          String   @id @default(cuid())
  agentId     String
  sessionId   String?
  type        String   // message, heartbeat, cron, webhook, hook, a2a, subagent
  priority    Int      @default(5) // 1-10, lower = higher priority
  status      String   @default("pending") // pending, processing, completed, failed
  payload     String   @default("{}") // JSON task data
  result      String?  // JSON result data
  error       String?
  source      String?  // origin of the task
  parentTaskId String?
  skillName    String?
  spawnDepth   Int      @default(0)
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  parentTask  Task?    @relation("TaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks  Task[]   @relation("TaskParent")
  deliveries  OutboundDelivery[]
  
  @@index([status, priority, createdAt])
  @@index([parentTaskId])
  @@map("tasks")
}

// OutboundDelivery - Durable outbox for channel response delivery
model OutboundDelivery {
  id                String   @id @default(cuid())
  taskId            String
  channel           String
  channelKey        String
  targetJson        String
  text              String
  deliveryType      String   @default("text") // text, file
  filePath          String?
  status            String   @default("pending") // pending, sent, failed
  attempts          Int      @default(0)
  nextAttemptAt     DateTime?
  lastError         String?
  sentAt            DateTime?
  externalMessageId String?
  dedupeKey         String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt, createdAt])
  @@index([taskId])
  @@map("outbound_deliveries")
}

// Trigger - Scheduled or event-based triggers
model Trigger {
  id          String   @id @default(cuid())
  agentId     String
  name        String
  type        String   // heartbeat, cron, webhook, hook
  config      String   @default("{}") // JSON configuration
  enabled     Boolean  @default(true)
  lastTriggered DateTime?
  nextTrigger   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@map("triggers")
}

// Memory - Persistent storage entries
model Memory {
  id                String    @id @default(cuid())
  agentId           String
  key               String    // memory key (e.g., "preferences", "context", "history")
  value             String    // Markdown content
  category          String    @default("general") // general, preferences, history, context, extracted, archived
  confidence        Float     @default(1.0)
  lastReinforcedAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
   agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
   chunks      MemoryChunk[]
   indexState  MemoryIndexState?
   
  @@unique([agentId, key])
  @@map("memories")
}

model MemoryChunk {
  id                  String          @id @default(cuid())
  memoryId            String
  agentId             String
  memoryKey           String
  chunkIndex          Int
  content             String
  normalizedContent   String
  contentHash         String
  tokenEstimate       Int
  charCount           Int
  embeddingCacheId    String?
  embeddingProvider   String?
  embeddingModel      String?
  embeddingVersion    String?
  embeddingDimensions Int?
  embeddingJson       String?
  indexedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  memory         Memory         @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  embeddingCache EmbeddingCache? @relation(fields: [embeddingCacheId], references: [id], onDelete: SetNull)

  @@unique([memoryId, chunkIndex])
  @@index([agentId, memoryKey])
  @@index([embeddingCacheId])
  @@map("memory_chunks")
}

model MemoryIndexState {
  id                  String    @id @default(cuid())
  memoryId            String    @unique
  agentId             String
  status              String    @default("pending")
  lastContentHash     String?
  lastIndexedAt       DateTime?
  lastError           String?
  attempts            Int       @default(0)
  embeddingProvider   String?
  embeddingModel      String?
  embeddingVersion    String?
  embeddingDimensions Int?
  vectorMode          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
  @@map("memory_index_states")
}

model EmbeddingCache {
  id         String    @id @default(cuid())
  contentHash String
  normalizedContent String
  provider   String
  model      String
  version    String
  dimensions Int
  embedding  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  chunks MemoryChunk[]

  @@unique([contentHash, provider, model, version, dimensions])
  @@map("embedding_cache")
}

model MemoryIndexMetadata {
  id        String   @id @default(cuid())
  indexName String
  scopeKey  String   @default("global")
  status    String   @default("pending")
  details   String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([indexName, scopeKey])
  @@map("memory_index_metadata")
}

model MemoryRecallLog {
  id             String   @id @default(cuid())
  agentId        String
  mode           String
  query          String?
  retrievalMode  String
  candidateCounts String  @default("{}")
  selectedKeys   String   @default("[]")
  omittedKeys    String   @default("[]")
  selectedCount  Int      @default(0)
  omittedCount   Int      @default(0)
  estimatedTokens Int     @default(0)
  details        String   @default("{}")
  createdAt      DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@map("memory_recall_logs")
}

// WebhookLog - Track incoming webhooks
model WebhookLog {
  id          String   @id @default(cuid())
  source      String   // github, jira, custom, etc.
  payload     String   // JSON payload
  processed   Boolean  @default(false)
  taskId      String?  // Created task ID if processed
  createdAt   DateTime @default(now())
  
  @@map("webhook_logs")
}

// AuditLog - Security audit trail
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // task_created, task_completed, agent_action, etc.
  entityType  String   // agent, task, trigger, memory
  entityId    String
  details     String   @default("{}") // JSON details
  severity    String   @default("info") // info, warning, error, critical
  createdAt   DateTime @default(now())
  
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
